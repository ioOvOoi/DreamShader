Shader(Name="DreamShaderTests/Corpus/M_VecAliases")
{
    Settings = {
        Domain = "UI";
        ShadingModel = "Unlit";
    }

    Outputs = {
        vec3 Color;
        Base.EmissiveColor = Color;
    }

    Graph = {
        float a = 1.0;
        vec2 uv = vec2(0.5, 0.5);
        vec3 rgb = vec3(uv.x, uv.y, a);
        vec4 c = vec4(rgb, 1.0);
        Color = c.rgb;
    }
}
