Shader(Name="DreamShaderTests/Corpus/M_IfElse")
{
    Properties = {
        float Mask = 0.6;
        vec3 Tint = vec3(1.0, 0.2, 0.2);
    }

    Settings = {
        Domain = "UI";
        ShadingModel = "Unlit";
    }

    Outputs = {
        vec3 Color;
        Base.EmissiveColor = Color;
    }

    Graph = {
        if (Mask > 0.5) {
            Color = Tint;
        } else {
            Color = vec3(0.0, 0.0, 0.0);
        }
    }
}
