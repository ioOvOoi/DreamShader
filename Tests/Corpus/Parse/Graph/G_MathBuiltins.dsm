Shader(Name="DreamShaderTests/Corpus/M_MathBuiltins")
{
    Properties = { float X = 0.5; vec3 A = vec3(1.0, 0.0, 0.0); vec3 B = vec3(0.0, 1.0, 0.0); }
    Settings = { Domain = "UI"; ShadingModel = "Unlit"; }
    Outputs = { vec3 Color; Base.EmissiveColor = Color; }
    Graph = {
        float s = sin(X);
        float c = cos(X);
        float cl = clamp(X, 0.0, 1.0);
        float sa = saturate(X);
        vec3 mixed = lerp(A, B, sa);
        Color = mixed * (s + c + cl);
    }
}
