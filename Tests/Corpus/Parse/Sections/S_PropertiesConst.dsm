Shader(Name="DreamShaderTests/Corpus/M_Const")
{
    Properties = {
        const float DebugScale = 1.0;
        float Strength = 1.0;
        vec3 Tint = vec3(1.0, 1.0, 1.0);
    }

    Settings = {
        Domain = "UI";
        ShadingModel = "Unlit";
    }

    Outputs = {
        vec3 Color;
        Base.EmissiveColor = Color;
    }

    Graph = {
        Color = Tint * Strength;
    }
}
